{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install"
  },
  "deploy": {
    "startCommand": "cd backend && npm start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  },
  "env": {
    "NODE_ENV": "production",
    "ML_SERVICE_URL": "${ML_SERVICE_URL}",
    "MONGODB_URI": "${MONGODB_URI}"
  }
}