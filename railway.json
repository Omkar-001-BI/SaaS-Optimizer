{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python app.py"
  },
  "services": [
    {
      "name": "ml-service",
      "source": {
        "root": "."
      },
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "python app.py",
        "healthcheckPath": "/",
        "healthcheckTimeout": 300
      },
      "env": {
        "PYTHON_VERSION": "3.11"
      }
    },
    {
      "name": "backend",
      "source": {
        "root": "backend"
      },
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "npm start",
        "healthcheckPath": "/",
        "healthcheckTimeout": 300
      },
      "env": {
        "NODE_ENV": "production",
        "ML_SERVICE_URL": "${ml-service.RAILWAY_STATIC_URL}"
      }
    },
    {
      "name": "frontend",
      "source": {
        "root": "frontend"
      },
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "npm start",
        "healthcheckPath": "/",
        "healthcheckTimeout": 300
      },
      "env": {
        "NODE_ENV": "production",
        "REACT_APP_API_URL": "${backend.RAILWAY_STATIC_URL}"
      }
    }
  ]
}